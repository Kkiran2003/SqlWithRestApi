<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>user detail</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <table>
      <tr>
        <th>id</th>
        <th>username</th>
        <th>email</th>
        <th>password</th>
        <th>Action</th>
      </tr>

      <tr>
        <td><%= user.id %></td>
        <td><%= user.username %></td>
        <td><%= user.email %></td>
        <td><%= user.password %></td>
        <td>
          <form method="get" action="/user/<%= user.id %>/edit">
            <button>edit username</button>
          </form>
           <form method="get" action="/user">
            <button>show all users</button>
          </form>

        </td>
      </tr>
    </table>
    <form method="get" action="/user/add">
            <button>add new users</button>
          </form>
  </body>
</html>
